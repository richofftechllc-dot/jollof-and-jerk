{
  "version": 2,
  "name": "jollof-and-jerk",
  "builds": [
    { "src": "maintenance.html", "use": "@vercel/static" },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "assets/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/.*", "status": 503, "dest": "/maintenance.html" }
  ]
}
